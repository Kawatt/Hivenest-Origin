{
	"name": "Mellivore",
	"description": "Food doesn't give any nutrients. You passively eat the honey you produce.",
	"type": "apoli:multiple",
	"modify": {
		"type": "apoli:modify_food",
		"food_modifier": {
			"operation": "multiply_total",
			"value": -1
		},
		"saturation_modifier": {
			"operation": "multiply_total",
			"value": -1
		}
	},
	"feed": {
		"type": "apoli:action_over_time",
		"interval": 20,
		"entity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "apoli:change_resource",
					"resource": "*:apicultured_honey",
					"change": -10
				},
				{
					"type": "apoli:feed",
					"food": 1,
					"saturation": 0.2
				}
			]
		},
		"condition": {
			"type": "apoli:and",
			"conditions": [
				{
					"type": "apoli:food_level",
					"comparison": "<",
					"compare_to": 20
				},
				{
					"type": "apoli:resource",
					"resource": "*:apicultured_honey",
					"comparison": ">",
					"compare_to": 0
				}
			]
		}
	}
}