{
	"name": "Hive Armory",
	"description": "You can equip bees with weapons and armor. A bee with a weapon won't lose their stinger when attacking. Use shears to take your equipment back.",
	"type": "apoli:multiple",
	"equiphelmet": {
		"type": "apoli:action_on_entity_use",
		"bientity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "apoli:target_action",
					"action": {
						"type": "apoli:drop_inventory",
						"slots": [
							"armor.head"
						]
					}
				},
				{
					"type": "hivenestkwt:copy_stack_to",
					"actor_slot": "weapon.mainhand",
					"target_slot": "armor.head"
				},
				{
					"type": "apoli:actor_action",
					"action": {
						"type": "apoli:execute_command",
						"command": "item replace entity @s weapon.mainhand with air"
					}
				},
				{
					"type": "apoli:target_action",
					"action": {
						"type": "apoli:execute_command",
						"command": "data modify entity @s ArmorDropChances set value [2.0f,2.0f,2.0f,2.0f]"
					}
				}
			]
		},
		"bientity_condition": {
			"type": "apoli:target_condition",
			"condition": {
				"type": "apoli:entity_type",
				"entity_type": "minecraft:bee"
			}
		},
		"condition": {
			"type": "apoli:equipped_item",
			"equipment_slot": "mainhand",
			"item_condition": {
				"type": "hivenestkwt:is_helmet"
			}
		}
	},
	"equipweapon": {
		"type": "apoli:action_on_entity_use",
		"bientity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "apoli:target_action",
					"action": {
						"type": "apoli:drop_inventory",
						"slots": [
							"weapon.mainhand"
						]
					}
				},
				{
					"type": "hivenestkwt:copy_stack_to",
					"actor_slot": "weapon.mainhand",
					"target_slot": "weapon.mainhand"
				},
				{
					"type": "apoli:actor_action",
					"action": {
						"type": "apoli:execute_command",
						"command": "item replace entity @s weapon.mainhand with air"
					}
				},
				{
					"type": "apoli:target_action",
					"action": {
						"type": "apoli:execute_command",
						"command": "data modify entity @s HandDropChances set value [2.0f,2.0f]"
					}
				},
				{
					"type": "apoli:target_action",
					"action": {
						"type": "apoli:play_sound",
						"sound": "item.armor.equip_generic"
					}
				}
			]
		},
		"bientity_condition": {
			"type": "apoli:target_condition",
			"condition": {
				"type": "apoli:entity_type",
				"entity_type": "minecraft:bee"
			}
		},
		"condition": {
			"type": "apoli:equipped_item",
			"equipment_slot": "mainhand",
			"item_condition": {
				"type": "hivenestkwt:is_tool"
			}
		}
	},
