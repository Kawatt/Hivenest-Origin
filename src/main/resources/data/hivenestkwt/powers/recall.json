{
    "name": "Swarm Recall",
    "description": "Call your bees towards your location. Bees liberated while sneaking will be instructed to not answer your calls.",
    "type": "apoli:multiple",
    "set": {
        "type": "apoli:entity_set"
    },
    "active": {
        "type": "apoli:active_self",
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:execute_command",
                    "command": "tag @s add hivenestkwt.tp"
                },
                {
                    "type": "apoli:action_on_set",
                    "set": "*:*_set",
                    "bientity_action": {
                        "type": "apoli:target_action",
                        "action": {
                            "type": "apoli:execute_command",
                            "command": "tp @s @a[tag=hivenestkwt.tp,limit=1,sort=nearest]"
                        }
                    },
                    "bientity_condition": {
                        "type": "apoli:distance",
                        "comparison": "<=",
                        "compare_to": 32
                    }
                },
                {
                    "type": "apoli:execute_command",
                    "command": "tag @s remove hivenestkwt.tp"
                },
                {
                    "type": "apoli:play_sound",
                    "sound": "block.beehive.work",
                    "pitch": 2
                }
            ]
        },
        "key": "key.origins.secondary_active",
        "cooldown": 60,
        "hud_render": {
            "should_render": false
        }
    }
}