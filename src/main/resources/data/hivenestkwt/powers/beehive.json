{
	"name": "Beenest",
	"description": "You can pick up and store up to 6 bees. Picking up bees restores their health at the cost of honey.",
	"type": "apoli:multiple",
	"storage": {
		"type": "hivenestkwt:entity_storage",
		"action_on_add": {
			"type": "apoli:target_action",
			"action": {
				"type": "apoli:execute_command",
				"command": "say captured"
			}
		},
		"action_on_remove": {
			"type": "apoli:target_action",
			"action": {
				"type": "apoli:execute_command",
				"command": "say released"
			}
		}
	},
	"addto": {
		"type": "apoli:action_on_entity_use",
		"bientity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "hivenestkwt:add_to_entity_storage",
					"storage": "*:*_storage"
				}
			]
		},
		"bientity_condition": {
			"type": "apoli:target_condition",
			"condition": {
				"type": "apoli:command",
				"command": "execute if data entity @s Leash",
				"comparison": "==",
				"compare_to": 0
			}
		},
		"condition": {
			"type": "apoli:and",
			"conditions": [
				{
					"type": "apoli:equipped_item",
					"equipment_slot": "mainhand",
					"item_condition": {
						"type": "apoli:empty"
					}
				},
				{
					"type": "hivenestkwt:entity_storage_size",
					"compare_to": 6,
					"comparison": "<",
					"storage": "*:*_storage"
				}
			]
		}
	},
	"removefrom": {
		"type": "apoli:active_self",
		"entity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "hivenestkwt:remove_from_entity_storage",
					"storage": "*:*_storage",
					"strategy": "first"
				}
			]
		},
		"key": "key.drop",
		"condition": {
			"type": "hivenestkwt:entity_storage_size",
			"compare_to": 0,
			"comparison": ">",
			"storage": "*:*_storage"
		}
	}
}