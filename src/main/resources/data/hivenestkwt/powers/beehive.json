{
	"type": "apoli:multiple",
	"storage": {
		"type": "hivenestkwt:entity_storage"
	},
	"addto": {
		"type": "apoli:action_on_entity_use",
		"bientity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "hivenestkwt:add_to_entity_storage",
					"storage": "*:*_storage"
				},
				{
					"type": "apoli:actor_action",
					"action": {
						"type": "apoli:execute_command",
						"command": "say captured"
					}
				}
			]
		},
		"condition": {
			"type": "apoli:and",
			"conditions": [
				{
					"type": "apoli:equipped_item",
					"equipment_slot": "mainhand",
					"item_condition": {
						"type": "apoli:empty"
					}
				},
				{
					"type": "hivenestkwt:storage_size",
					"compare_to": 6,
					"comparison": "<",
					"storage": "*:*_storage"
				}
			]
		}
	},
	"removefrom": {
		"type": "apoli:active_self",
		"entity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "hivenestkwt:remove_from_entity_storage",
					"storage": "*:*_storage",
					"strategy": "first"
				},
				{
					"type": "apoli:execute_command",
					"command": "say released"
				}
			]
		},
		"key": "key.drop",
		"condition": {
			"type": "hivenestkwt:storage_size",
			"compare_to": 0,
			"comparison": ">",
			"storage": "*:*_storage"
		}
	},
	"beeexit": {
		"type": "apoli:action_on_block_use",
		"block_action": {
			"type": "hivenestkwt:spawn_entity_from_beehive"
		},
		"hands": ["main_hand"],
		"block_condition": {
			"type": "apoli:and",
			"conditions": [
				{
					"type": "hivenestkwt:is_beehive"
				},
				{
					"type": "hivenestkwt:facing_at_block",
					"block_condition": {
						"type": "apoli:movement_blocking",
						"inverted": true
					}
				}
			]
		},
		"condition": {
			"type": "apoli:sneaking"
		}
	}
}