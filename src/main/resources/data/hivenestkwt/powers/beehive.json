{
	"name": "Bee Nest",
	"description": "You can pick up and store up to 6 bees. Picking up bees restores their health at the cost of honey if below half health.",
	"type": "apoli:multiple",
	"storage": {
		"type": "hivenestkwt:entity_storage",
		"action_on_add": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "apoli:actor_action",
					"action": {
						"type": "apoli:play_sound",
						"sound": "minecraft:block.beehive.enter"
					}
				},
				{
					"type": "apoli:if_else",
					"condition": {
						"type": "apoli:and",
						"conditions": [
							{
								"type": "apoli:target_condition",
								"condition": {
									"type": "apoli:relative_health",
									"comparison": "<=",
									"compare_to": 0.5
								}
							},
							{
								"type": "apoli:actor_condition",
								"condition": {
									"type": "apoli:resource",
									"resource": "*:apicultured_honey",
									"comparison": ">=",
									"compare_to": 10
								}
							}
						]
					},
					"if_action": {
						"type": "apoli:and",
						"actions": [
							{
								"type": "apoli:actor_action",
								"action": {
									"type": "apoli:change_resource",
									"resource": "*:apicultured_honey",
									"change": -10
								}
							},
							{
								"type": "apoli:target_action",
								"action": {
									"type": "apoli:heal",
									"amount": 20
								}
							}
						]
					}
				},
				{
					"type": "apoli:if_else",
					"condition": {
						"type": "apoli:target_condition",
						"condition": {
							"type": "apoli:command",
							"command": "execute if data entity @s {HasNectar:1b}",
							"comparison": "==",
							"compare_to": 1
						}
					},
					"if_action": {
						"type": "apoli:and",
						"actions": [
							{
								"type": "apoli:actor_action",
								"action": {
									"type": "apoli:change_resource",
									"resource": "*:apicultured_pollen",
									"change": 10
								}
							},
							{
								"type": "apoli:target_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "data modify entity @s HasNectar set value 0b"
								}
							}
						]
					}
				},
				{
					"type": "apoli:if_else",
					"condition": {
						"type": "apoli:target_condition",
						"condition": {
							"type": "apoli:command",
							"command": "execute if data entity @s {CropsGrownSincePollination:0}",
							"comparison": "==",
							"compare_to": 0
						}
					},
					"if_action": {
						"type": "apoli:and",
						"actions": [
							{
								"type": "apoli:target_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "function hivenestkwt:getamount"
								}
							},
							{
								"type": "apoli:actor_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "function hivenestkwt:getflower"
								}
							},
							{
								"type": "apoli:actor_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "function hivenestkwt:giveflowers with storage hivenestkwt:storage"
								}
							},
							{
								"type": "apoli:target_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "data modify entity @s CropsGrownSincePollination set value 0"
								}
							},
							{
								"type": "apoli:actor_action",
								"action": {
									"type": "apoli:execute_command",
									"command": "particle minecraft:composter ~ ~1 ~ 0.5 0.5 0.5 0.2 10"
								}
							}
						]
					}
				}
			]
		},
		"action_on_remove": {
			"type": "apoli:actor_action",
			"action": {
				"type": "apoli:play_sound",
				"sound": "minecraft:block.beehive.exit"
			}
		}
	},
	"addto": {
		"type": "apoli:action_on_entity_use",
		"bientity_action": {
			"type": "apoli:if_else",
			"condition": {
				"type": "apoli:actor_condition",
				"condition": {
					"type": "hivenestkwt:entity_storage_size",
					"compare_to": 6,
					"comparison": "<",
					"storage": "*:*_storage"
				}
			},
			"if_action": {
				"type": "hivenestkwt:add_to_entity_storage",
				"storage": "*:*_storage"
			},
			"else_action": {
				"type": "apoli:actor_action",
				"action": {
					"type": "apoli:play_sound",
					"sound": "block.beehive.enter",
					"pitch": 2
				}
			}
		},
		"bientity_condition": {
			"type": "apoli:target_condition",
			"condition": {
				"type": "apoli:and",
				"conditions": [
					{
						"type": "apoli:command",
						"command": "execute if data entity @s Leash",
						"comparison": "==",
						"compare_to": 0
					},
					{
						"type": "apoli:entity_type",
						"entity_type": "minecraft:bee"
					}
				]
			}
		},
		"condition": {
			"type": "apoli:and",
			"conditions": [
				{
					"type": "apoli:equipped_item",
					"equipment_slot": "mainhand",
					"item_condition": {
						"type": "apoli:empty"
					}
				}
			]
		}
	},
	"removefrom": {
		"type": "apoli:active_self",
		"entity_action": {
			"type": "apoli:and",
			"actions": [
				{
					"type": "hivenestkwt:remove_from_entity_storage",
					"storage": "*:*_storage",
					"strategy": "last"
				}
			]
		},
		"key": "key.origins.primary_active",
		"condition": {
			"type": "hivenestkwt:entity_storage_size",
			"compare_to": 0,
			"comparison": ">",
			"storage": "*:*_storage"
		}
	}
}