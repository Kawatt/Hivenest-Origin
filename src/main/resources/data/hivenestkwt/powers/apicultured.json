{
    "name": "Apicultured",
    "description": "Picking up bees with pollen will store it inside you. Overtime, pollen will be transformed into honey and wax.",
    "type": "apoli:multiple",
    "honey": {
        "type": "apoli:resource",
        "start_value": 100,
        "min": 0,
        "max": 700,
        "hud_render": {
            "sprite_location": "origins:textures/gui/community/spiderkolo/resource_bar_01.png",
            "bar_index": 0
        }
    },
    "pollen": {
        "type": "apoli:resource",
        "start_value": 0,
        "min": 0,
        "max": 700,
        "hud_render": {
            "bar_index": 0
        }
    },
    "fillhoney": {
        "type": "apoli:action_over_time",
        "interval": 200,
        "entity_action": {
            "type": "apoli:and",
            "actions": [
                {
                    "type": "apoli:change_resource",
                    "resource": "*:*_pollen",
                    "change": -10
                },
                {
                    "type": "apoli:change_resource",
                    "resource": "*:*_honey",
                    "change": 10
                }
            ]
        },
        "condition": {
            "type": "apoli:and",
            "conditions": [
                {
                    "type": "apoli:resource",
                    "resource": "*:*_pollen",
                    "comparison": ">=",
                    "compare_to": 10
                },
                {
                    "type": "apoli:resource",
                    "resource": "*:*_honey",
                    "comparison": "!=",
                    "compare_to": 700
                }
            ]
        }
    },
    "food": {
        "type": "apoli:action_on_item_use",
        "entity_action": {
            "type": "apoli:change_resource",
            "resource": "*:*_honey",
            "change": 10
        },
        "item_condition": {
            "type": "apoli:ingredient",
            "ingredient": {
                "tag": "*:honey"
            }
        }
    },
    "particles": {
        "type": "apoli:particle",
        "particle": "minecraft:falling_honey",
        "count": 1,
        "frequency": 10,
        "condition": {
            "type": "apoli:resource",
            "resource": "*:*_honey",
            "comparison": ">=",
            "compare_to": 500
        }
    }
}