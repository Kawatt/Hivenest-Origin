{
  "schemaVersion": 1,
  "id": "hivenestkwt",
  "version": "${version}",

  "name": "Hivenest",
  "description": "Apoli Addon that also adds the Hivenest origin and some bee changes.",
  "authors": [
    "Kawatt"
  ],
  "contact": {
    "homepage": "https://github.com/Kawatt",
    "sources": "https://github.com/Kawatt/Hivenest-Origin",
    "issues": "https://github.com/Kawatt/Hivenest-Origin/issues"
  },

  "license": "MIT",
  "icon": "assets/hivenestkwt/pack.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "io.github.kawatt.hivenestkwt.Hivenest"
    ],
    "client": [
      "io.github.kawatt.hivenestkwt.HivenestClient"
    ],
    "calio:ordered-resource-listener": [
      "io.github.kawatt.hivenestkwt.Hivenest"
    ]
  },
  "mixins": [
	  "modid.mixins.json"
  ],
  "depends": {
    "java": ">=17",
    "fabricloader": ">=0.15.3",
    "fabric-api": ">=0.91.2",
    "minecraft": "~1.20.2",
    "apoli": ">=2.10.0"
  },
  "breaks": {
    "optifabric": "<=1.11.18",
    "identity": "<1.14.2-beta"
  }
}
